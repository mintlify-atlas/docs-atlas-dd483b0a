  "keyFeatures": [
    "Multi-step event registration with Supabase backend and Zod validation",
    "Protected admin dashboard with Google OAuth and domain-restricted access",
    "Interactive event schedule with mobile and desktop timeline variants",
    "Media galleries with image carousels and custom video players",
    "Spiritual and community seva (service) submission forms",
    "Background audio system with auto-play and user consent handling",
    "Cloudflare R2 and Cloudflare Images CDN integration for optimized assets",
    "Smooth scroll animations using Framer Motion, GSAP, and Locomotive Scroll",
    "Responsive design following Atomic Design principles",
    "CSV export for admin registration management with streaming support"
  ],
  "publicApiSurface": [
    "GET/POST /api/registrations",
    "GET /api/admin/registrations",
    "GET /api/download",
    "POST /api/generate-upload-urls",
    "POST /api/generate-cs-personal-submission-upload-urls",
